# --- General ---
# Ignore dot-directories anywhere (e.g., .git/, .vscode/, .idea/, .pytest_cache/)
**/.*/

# Compiled Go binaries accidentally left at repo root by `go build`.
/audit-v775
# But allow .githooks (pre-commit hooks shared via repo)
!.githooks/
!.githooks/**
# --- Environment Variables & Secrets ---
# Ignore env files by default...
.env
.env.*
env.*

# Ignore plaintext image-warmer env (anywhere)
**/image-warmer.env

# But keep the encrypted SOPS version tracked (anywhere)
!**/image-warmer.env.sops

# Allow BOTH dot-prefixed and non-dot-prefixed encrypted env files anywhere EXCEPT inside dot-directories
!**/.env.enc
**/.*/.env.enc
!**/env.enc
**/.*/env.enc

# Allow example files and SOPS config (wherever they are), still subject to dot-directory ignore above
!**/.env.example
!**/env.example
!**/.sops.yaml

# --- Byte-compiled/optimized/DLL files ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environment ---
venv/
.venv/
env/
.env/
*env/
*env.bak/
*env.old/

# --- Application Outputs & Logs ---
.outputs/
logs/
*.log
*.log.*
output.txt
output*.txt
artifacts/test/

# --- IDE/Editor Configurations ---
# Note: dot-directories are already handled by **/.*/
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Build, Distribution, and Packaging Artifacts ---

dist/
*.egg-info/
pip-wheel-metadata/
/site/
*.egg
/wheels/
# Local debug runs — MHTML, screenshots, JSON output
.run/
# --- Testing & Coverage ---
.pytest_cache/
.coverage
.coverage.*
nosetests.xml
coverage.xml
htmlcov/
pytest-report.html

# --- Operating System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Docker ---
docker-compose.override.yml
docker-compose.local.yml

