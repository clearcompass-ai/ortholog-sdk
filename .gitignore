.terraform/
.tofu/
terraform.tfstate
terraform.tfstate.backup
tofu.tfstate
tofu.tfstate.backup
*.tfvars
*.tfplan
.terraform.lock.hcl
.tofu.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

