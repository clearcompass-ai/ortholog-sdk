// Helpers — adapt these to your test scaffolding
// -------------------------------------------------------------------------------------------------

// buildAndSignEntryBoundTo returns an *envelope.Entry with Destination
// set to `dest`, a valid signature from a freshly-generated keypair, and
// the signer DID wired into the verifier registry for the test.
//
// The exact body depends on your test helpers. Sketch:
//
//   1. Generate a secp256k1 keypair (or Ed25519 / P-256).
//   2. Derive a DID (did:key for simplicity in tests).
//   3. Register the DID's verification method in a resolver for tests.
//   4. Build an Entry with Destination=dest, SignerDID=the-derived-did.
//   5. Compute CanonicalHash(entry).
//   6. Sign the hash, attach the signature to the Entry via
//      envelope.AppendSignature or equivalent.
//   7. Return the Entry.
//
// This helper is intentionally left as a stub: every repo's test
// infrastructure for key generation and entry signing is slightly
// different. Fill it in with your local idioms.
func buildAndSignEntryBoundTo(t *testing.T, dest string) *envelope.Entry {
	t.Helper()
	t.Skip("buildAndSignEntryBoundTo: fill in with local test idioms — see function comment")
	return nil
}
