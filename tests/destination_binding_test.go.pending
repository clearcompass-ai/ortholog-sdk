/*
FILE PATH:
    tests/destination_binding_test.go

DESCRIPTION:
    Tests the destination-binding defense against cross-exchange replay.
    Every assertion here is a lock on a security invariant. A failure in
    this file indicates a potential cross-exchange forgery vector.

INVARIANTS LOCKED:
  1. DestinationCommitment is deterministic and injective.
  2. Empty, whitespace-padded, or over-long destinations are rejected at
     the validation boundary.
  3. The canonical hash of an Entry changes if Destination changes,
     holding every other field constant.
  4. A VerifierRegistry scoped to exchange A rejects an entry bound to
     exchange B, even with a cryptographically valid signature.
  5. The Build* helpers refuse to produce an entry with empty destination.
  6. Serialize → Deserialize round-trips the Destination field exactly.

KEY DEPENDENCIES:
    - core/envelope (Entry, Serialize, Deserialize, CanonicalHash, ValidateDestination, DestinationCommitment)
    - crypto/signatures (for key generation and signing in cross-replay test)
    - did (for VerifierRegistry and VerifyEntry)
    - builder (for BuildAmendment or similar; pick the simplest Build* that takes a Destination)

NOTE ON FIXTURES:
    No hex fixtures are locked here — the destination binding is a schema
    change, not a protocol constant. If you want to lock the exact hash of
    the destination commitment for "did:web:test.example.com", add a
    TestDestinationCommitment_KnownVector test with one precomputed value.
*/
package tests

import (
	"bytes"
	"errors"
	"strings"
	"testing"

	"github.com/clearcompass-ai/ortholog-sdk/core/envelope"
	"github.com/clearcompass-ai/ortholog-sdk/did"
)

// -------------------------------------------------------------------------------------------------
// 1) DestinationCommitment — determinism & injectivity
// -------------------------------------------------------------------------------------------------

func TestDestinationCommitment_Deterministic(t *testing.T) {
	const did = "did:web:courts.tn.gov:appellate"

	a, err := envelope.DestinationCommitment(did)
	if err != nil {
		t.Fatalf("DestinationCommitment (1): %v", err)
	}
	b, err := envelope.DestinationCommitment(did)
	if err != nil {
		t.Fatalf("DestinationCommitment (2): %v", err)
	}
	if !bytes.Equal(a[:], b[:]) {
		t.Fatal("DestinationCommitment is non-deterministic — same input must give same output")
	}
}

func TestDestinationCommitment_Injective_DifferentDIDs(t *testing.T) {
	a, err := envelope.DestinationCommitment("did:web:courts.tn.gov:appellate")
	if err != nil {
		t.Fatalf("a: %v", err)
	}
	b, err := envelope.DestinationCommitment("did:web:courts.nashville.gov:criminal")
	if err != nil {
		t.Fatalf("b: %v", err)
	}
	if bytes.Equal(a[:], b[:]) {
		t.Fatal("Different DIDs produced identical commitments — injectivity violated")
	}
}

func TestDestinationCommitment_SingleByteDifference(t *testing.T) {
	a, err := envelope.DestinationCommitment("did:web:a.example.com")
	if err != nil {
		t.Fatalf("a: %v", err)
	}
	b, err := envelope.DestinationCommitment("did:web:A.example.com") // only case differs
	if err != nil {
		t.Fatalf("b: %v", err)
	}
	if bytes.Equal(a[:], b[:]) {
		t.Fatal("Case-different DIDs collided — DID comparison is case-sensitive by design")
	}
}

// -------------------------------------------------------------------------------------------------
// 2) ValidateDestination — fail-loud at the boundary
// -------------------------------------------------------------------------------------------------

func TestValidateDestination_RejectsEmpty(t *testing.T) {
	if err := envelope.ValidateDestination(""); !errors.Is(err, envelope.ErrDestinationEmpty) {
		t.Fatalf("expected ErrDestinationEmpty, got %v", err)
	}
}

func TestValidateDestination_RejectsWhitespace(t *testing.T) {
	for _, bad := range []string{
		" did:web:a.com",
		"did:web:a.com ",
		"\tdid:web:a.com",
		"did:web:a.com\n",
	} {
		if err := envelope.ValidateDestination(bad); !errors.Is(err, envelope.ErrDestinationWhitespace) {
			t.Errorf("%q: expected ErrDestinationWhitespace, got %v", bad, err)
		}
	}
}

func TestValidateDestination_RejectsOverLong(t *testing.T) {
	tooLong := "did:web:" + strings.Repeat("x", envelope.MaxDestinationDIDLen)
	if err := envelope.ValidateDestination(tooLong); !errors.Is(err, envelope.ErrDestinationTooLong) {
		t.Fatalf("expected ErrDestinationTooLong, got %v", err)
	}
}

func TestValidateDestination_AcceptsTypical(t *testing.T) {
	for _, good := range []string{
		"did:web:courts.tn.gov:appellate",
		"did:pkh:eip155:1:0xabcdef0123456789abcdef0123456789abcdef01",
		"did:key:z6MkpTHR8VNsBxYAAWHut2Geadd9jSshuhTGhoLjSzhpUPo",
		"did:ethr:0xabc",
	} {
		if err := envelope.ValidateDestination(good); err != nil {
			t.Errorf("%q: expected nil, got %v", good, err)
		}
	}
}

// -------------------------------------------------------------------------------------------------
// 3) Commitment injectivity — ValidateDestination and commitment share contract
// -------------------------------------------------------------------------------------------------

func TestDestinationCommitment_RejectsInvalidInput(t *testing.T) {
	if _, err := envelope.DestinationCommitment(""); err == nil {
		t.Fatal("empty destination must be rejected by DestinationCommitment")
	}
	if _, err := envelope.DestinationCommitment(" did:web:a.com"); err == nil {
		t.Fatal("leading-whitespace destination must be rejected by DestinationCommitment")
	}
}

// -------------------------------------------------------------------------------------------------
// 4) Canonical hash — changes with destination
// -------------------------------------------------------------------------------------------------

// buildTwoEntriesDifferingOnlyByDestination is a helper that constructs two
// Entry values with identical content except for Destination. The exact
// builder used doesn't matter — the invariant is that two entries, same
// content, different destinations, MUST hash differently.
//
// If your Build* functions require more fixture scaffolding, substitute a
// minimal Entry constructor here. The key fact under test is the canonical
// hash binding, not the builder plumbing.
func buildTwoEntriesDifferingOnlyByDestination(t *testing.T) (*envelope.Entry, *envelope.Entry) {
	t.Helper()
	// Replace this with your actual builder if needed — e.g.,
	//   builder.BuildAmendment(builder.AmendmentConfig{...})
	// For this test we construct Entry directly. Adjust field names to
	// whatever your Entry struct actually has.
	base := &envelope.Entry{
		Version:     5,
		SignerDID:   "did:web:courts.tn.gov:appellate:judge-chen",
		Destination: "did:web:courts.tn.gov:appellate",
		// ... other required fields populated with placeholder values ...
	}
	alt := *base
	alt.Destination = "did:web:courts.nashville.gov:criminal"
	return base, &alt
}

func TestCanonicalHash_ChangesWithDestination(t *testing.T) {
	a, b := buildTwoEntriesDifferingOnlyByDestination(t)

	ha, err := envelope.EntryIdentity(a)
	if err != nil {
		t.Fatalf("CanonicalHash(a): %v", err)
	}
	hb, err := envelope.EntryIdentity(b)
	if err != nil {
		t.Fatalf("CanonicalHash(b): %v", err)
	}
	if bytes.Equal(ha[:], hb[:]) {
		t.Fatal("CanonicalHash is destination-blind — cross-exchange replay would be possible")
	}
}

// -------------------------------------------------------------------------------------------------
// 5) Serialize → Deserialize round-trip preserves Destination
// -------------------------------------------------------------------------------------------------

func TestEntrySerialize_PreservesDestination(t *testing.T) {
	orig := &envelope.Entry{
		Version:     5,
		SignerDID:   "did:web:courts.tn.gov:appellate:judge-chen",
		Destination: "did:web:courts.tn.gov:appellate",
		// ... other required fields ...
	}
	raw, err := envelope.Serialize(orig)
	if err != nil {
		t.Fatalf("Serialize: %v", err)
	}
	back, err := envelope.Deserialize(raw)
	if err != nil {
		t.Fatalf("Deserialize: %v", err)
	}
	if back.Destination != orig.Destination {
		t.Fatalf("Destination not preserved: got %q, want %q",
			back.Destination, orig.Destination)
	}
}

// -------------------------------------------------------------------------------------------------
// 6) Entry.Validate rejects empty destination
// -------------------------------------------------------------------------------------------------

func TestEntry_Validate_RejectsEmptyDestination(t *testing.T) {
	e := &envelope.Entry{
		Version:     5,
		SignerDID:   "did:web:courts.tn.gov:appellate:judge-chen",
		Destination: "",
		// ... other fields ...
	}
	err := e.Validate()
	if !errors.Is(err, envelope.ErrDestinationEmpty) {
		t.Fatalf("expected ErrDestinationEmpty, got %v", err)
	}
}

// -------------------------------------------------------------------------------------------------
// 7) Cross-destination verification — the primary security assertion
// -------------------------------------------------------------------------------------------------

// TestVerifyEntry_CrossDestination_Rejected is the keystone test: it
// constructs a valid signed entry for exchange A, attempts to verify it
// against a registry scoped to exchange B, and asserts rejection.
//
// This is the test that must NEVER be allowed to regress.
func TestVerifyEntry_CrossDestination_Rejected(t *testing.T) {
	const (
		destA = "did:web:courts.tn.gov:appellate"
		destB = "did:web:courts.nashville.gov:criminal"
	)

	// Construct an entry bound to destA. Use whatever builder / signing
	// flow is normal in your tests — the important property is:
	//   entry.Destination == destA
	// and the signature is a valid signature over CanonicalHash(entry).
	entryForA := buildAndSignEntryBoundTo(t, destA)

	// Build a registry scoped to destB.
	registryForB, err := did.NewVerifierRegistry(destB)
	if err != nil {
		t.Fatalf("NewVerifierRegistry(destB): %v", err)
	}
	// If DefaultVerifierRegistry is your preferred wiring:
	// registryForB := did.DefaultVerifierRegistry(destB, testResolver)

	err = registryForB.VerifyEntry(entryForA)
	if err == nil {
		t.Fatal("registry for destB accepted entry bound to destA — cross-exchange replay possible")
	}
	if !strings.Contains(err.Error(), "destination mismatch") {
		t.Fatalf("expected destination-mismatch error, got: %v", err)
	}
}

// -------------------------------------------------------------------------------------------------
// 8) Same-destination verification succeeds (sanity check)
// -------------------------------------------------------------------------------------------------

func TestVerifyEntry_SameDestination_Accepted(t *testing.T) {
	const dest = "did:web:courts.tn.gov:appellate"

	entry := buildAndSignEntryBoundTo(t, dest)

	registry, err := did.NewVerifierRegistry(dest)
	if err != nil {
		t.Fatalf("NewVerifierRegistry: %v", err)
	}
	if err := registry.VerifyEntry(entry); err != nil {
		t.Fatalf("same-destination VerifyEntry: %v", err)
	}
}

